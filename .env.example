# ─── ADS-B Source ──────────────────────────────────────────────
ADSB_SOURCE=opensky            # opensky | sbs | beast
OPENSKY_USERNAME=              # leave blank for anonymous (rate-limited)
OPENSKY_PASSWORD=

# Local dump1090 (if using sbs or beast mode)
DUMP1090_HOST=localhost
DUMP1090_PORT=30003
DUMP1090_BEAST_PORT=30005

# ─── Infrastructure ────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:29092
REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql://skysecure:skysecure_secret@postgres:5432/skysecure

# ─── API ───────────────────────────────────────────────────────
API_CORS_ORIGINS=["http://localhost:3000"]
WS_BROADCAST_INTERVAL=1.0

# ─── Detection Thresholds ──────────────────────────────────────
MAX_GROUNDSPEED_KNOTS=1200.0
MAX_ALTITUDE_JUMP_FT=5000
FUSION_CONFLICT_NM=5.0
MIL_SCORE_THRESHOLD=0.5

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
